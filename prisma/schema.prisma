generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user") // user, admin, owner
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  trades        Trade[]
  tradingAccounts TradingAccount[]
  goals         Goal[]
  propFirmAccounts PropFirmAccount[]
  dailyJournals DailyJournal[]
  coachInsights CoachInsight[]
  checklistItems ChecklistItem[]
  reports       Report[]
  tags          Tag[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TradingAccount {
  id        String   @id @default(cuid())
  userId    String
  name      String
  broker    String?
  type      String   @default("live") // live, demo, prop
  balance   Float    @default(0)
  currency  String   @default("USD")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([userId])
}

model Trade {
  id              String   @id @default(cuid())
  userId          String
  accountId       String?
  instrument      String
  direction       String   // long, short
  entryPrice      Float
  exitPrice       Float?
  stopLoss        Float?
  takeProfit      Float?
  quantity         Float    @default(1)
  commission      Float    @default(0)
  result          Float?
  resultPercent   Float?
  status          String   @default("open") // open, closed, cancelled
  setup           String?
  session         String?  // asia, london, new_york, overlap
  entryDate       DateTime
  exitDate        DateTime?
  duration        Int?     // in minutes
  notes           String?  @db.Text
  rating          Int?     // 1-5
  riskReward      Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     TradingAccount? @relation(fields: [accountId], references: [id])
  screenshots Screenshot[]
  emotions    TradeEmotion[]
  mistakes    TradeMistake[]
  tags        TradeTag[]

  @@index([userId])
  @@index([userId, entryDate])
  @@index([userId, status])
}

model Screenshot {
  id        String   @id @default(cuid())
  tradeId   String
  url       String
  caption   String?
  createdAt DateTime @default(now())

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model Tag {
  id        String     @id @default(cuid())
  userId    String
  name      String
  color     String     @default("#D4AF37")
  createdAt DateTime   @default(now())

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades TradeTag[]

  @@unique([userId, name])
}

model TradeTag {
  id      String @id @default(cuid())
  tradeId String
  tagId   String

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tradeId, tagId])
}

model TradeEmotion {
  id       String @id @default(cuid())
  tradeId  String
  emotion  String // confident, fearful, greedy, calm, frustrated, excited, anxious, neutral

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model TradeMistake {
  id       String @id @default(cuid())
  tradeId  String
  mistake  String // moved_stop, early_exit, late_entry, oversize, revenge_trade, no_plan, fomo, broke_rules

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model Goal {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  type        String   // daily, weekly, monthly, profit, consistency, habit, discipline
  target      Float
  current     Float    @default(0)
  unit        String   @default("trades") // trades, dollars, percent, streak
  startDate   DateTime
  endDate     DateTime?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
}

model PropFirmAccount {
  id                String   @id @default(cuid())
  userId            String
  firmName          String
  accountSize       Float
  currentBalance    Float
  dailyLossLimit    Float
  overallMaxLoss    Float
  trailingDrawdown  Boolean  @default(false)
  profitTarget      Float
  activeTradingDays Int      @default(0)
  requiredDays      Int?
  consistencyRule   String?
  phase             String   @default("challenge") // challenge, verification, funded, failed
  status            String   @default("active") // active, passed, failed, payout
  startDate         DateTime
  endDate           DateTime?
  payoutAmount      Float    @default(0)
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DailyJournal {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime
  preMarketNotes  String?  @db.Text
  postMarketNotes String?  @db.Text
  mood            Int?     // 1-10
  sleepHours      Float?
  stressLevel     Int?     // 1-10
  confidence      Int?     // 1-10
  discipline      Int?     // 1-10
  followedPlan    Boolean?
  lessonLearned   String?  @db.Text
  gratitude       String?
  tomorrowPlan    String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model CoachInsight {
  id        String   @id @default(cuid())
  userId    String
  type      String   // alert, tip, warning, achievement, plan
  category  String   // risk, performance, discipline, emotion, pattern, streak
  title     String
  message   String   @db.Text
  severity  String   @default("info") // info, warning, critical, success
  isRead    Boolean  @default(false)
  data      String?  @db.Text // JSON data for context
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model ChecklistItem {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String   @default("pre-trade") // pre-trade, during-trade, post-trade, daily
  order       Int      @default(0)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Report {
  id        String   @id @default(cuid())
  userId    String
  type      String   // daily, weekly, monthly
  startDate DateTime
  endDate   DateTime
  data      String   @db.Text // JSON report data
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
}


model Application {
  id              String   @id @default(cuid())
  name            String
  email           String
  discord         String?
  plan            String
  experience      String
  market          String?
  goal            String?
  biggestStruggle String?  @db.Text
  moneyLost       String?
  triedBefore     String?  @db.Text
  availability    String?
  whyNow          String?  @db.Text
  message         String?  @db.Text
  status          String   @default("pending") // pending, contacted, accepted, rejected
  notes           String?  @db.Text // Your internal notes about this applicant
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
